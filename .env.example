# ============================================================================
# AtlasRAG Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control!
# See .gitignore for .env patterns

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# Which LLM provider to use: ollama, openai, or gemini
# Default: ollama (for local, privacy-preserving development)
LLM_PROVIDER=ollama

# ---------- Ollama Configuration (local LLM) ----------
# Base URL for Ollama service (running on your machine or Docker)
OLLAMA_BASE_URL=http://localhost:11434

# Model name to use (must be installed via ollama pull)
# Common options: llama2, mistral, neural-chat, dolphin-mixtral
OLLAMA_MODEL=llama2

# Model for embeddings (must be installed)
# Recommended: nomic-embed-text (fast, good quality)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ---------- OpenAI Configuration (cloud LLM) ----------
# Get your API key from: https://platform.openai.com/api-keys
# Leave empty to disable OpenAI provider
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use (e.g., gpt-4-turbo-preview, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4-turbo-preview

# Embedding model for semantic search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------- Google Gemini Configuration (cloud LLM) ----------
# Get your API key from: https://makersuite.google.com/app/apikey
# Leave empty to disable Gemini provider
GEMINI_API_KEY=your-gemini-api-key-here

# Model to use
GEMINI_MODEL=gemini-1.5-pro

# Embedding model (Gemini's built-in embedding)
GEMINI_EMBEDDING_MODEL=models/embedding-001

# ============================================================================
# Vector Store Configuration
# ============================================================================

# Which vector database to use: chroma or milvus
# Default: chroma (local, file-based, easiest for development)
VECTOR_STORE=chroma

# ---------- Chroma Configuration (local vector database) ----------
# Directory to persist Chroma data locally
CHROMA_PERSIST_DIRECTORY=./chroma_data

# Collection name (namespace for documents)
CHROMA_COLLECTION_NAME=atlasrag_documents

# ---------- Milvus Configuration (scalable vector database) ----------
# Milvus server hostname (in Docker: 'milvus', localhost otherwise)
MILVUS_HOST=localhost

# Milvus server port (default: 19530)
MILVUS_PORT=19530

# Milvus username (default: root)
MILVUS_USER=root

# Milvus password (default: Milvus)
MILVUS_PASSWORD=Milvus

# Milvus collection name
MILVUS_COLLECTION_NAME=atlasrag_documents

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL connection string for metadata storage
# Format: postgresql://user:password@host:port/database
# In Docker: postgresql://atlasrag:atlasrag_dev_password@postgres:5432/atlasrag
DATABASE_URL=postgresql://atlasrag:atlasrag_dev_password@localhost:5432/atlasrag

# Connection pool size
DATABASE_POOL_SIZE=10

# Maximum overflow connections
DATABASE_MAX_OVERFLOW=20

# ============================================================================
# API Server Configuration
# ============================================================================

# Bind address (0.0.0.0 = all interfaces)
API_HOST=0.0.0.0

# Server port
API_PORT=8000

# Number of Uvicorn worker processes
API_WORKERS=4

# Enable auto-reload on code changes (development only!)
API_RELOAD=true

# Debug mode (enables extra logging, stack traces, etc.)
DEBUG=true

# ---------- CORS Settings ----------
# Comma-separated list of allowed origins for CORS
# Examples: http://localhost:3000,http://localhost:8000,https://app.example.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000

# Allow credentials (cookies, auth headers)
CORS_ALLOW_CREDENTIALS=true

# Allowed HTTP methods
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed HTTP headers
CORS_ALLOW_HEADERS=*

# ============================================================================
# Document Ingestion Configuration
# ============================================================================

# Chunk size in characters (split documents into this size)
CHUNK_SIZE=1000

# Overlap between chunks (for context preservation)
CHUNK_OVERLAP=200

# Maximum document size in MB (prevents processing huge files)
MAX_DOCUMENT_SIZE_MB=50

# Supported file extensions (comma-separated)
SUPPORTED_FILE_TYPES=.pdf,.docx,.txt,.html,.md

# ============================================================================
# Retrieval Configuration
# ============================================================================

# Number of document chunks to retrieve per query
RETRIEVAL_TOP_K=5

# Minimum similarity score threshold (0.0 to 1.0)
# Only return documents with similarity >= this threshold
SIMILARITY_THRESHOLD=0.7

# Enable re-ranking of retrieved documents (sorts by relevance)
ENABLE_RERANKING=true

# ============================================================================
# Agent Configuration
# ============================================================================

# Maximum number of verification→repair loop iterations
MAX_REPAIR_ITERATIONS=2

# Minimum percentage of sentences that must have citations
MIN_CITATION_COVERAGE=0.95

# Verification strictness: strict, moderate, or lenient
# - strict: Every claim must have supporting source
# - moderate: Allow some claims without citations
# - lenient: Only flag if answer is completely unsupported
VERIFICATION_MODE=strict

# Timeout for each agent in seconds
AGENT_TIMEOUT_SECONDS=60

# ============================================================================
# Observability Configuration
# ============================================================================

# Enable OpenTelemetry distributed tracing
ENABLE_TRACING=true

# Enable Prometheus metrics collection
ENABLE_METRICS=true

# Prometheus metrics endpoint port
METRICS_PORT=9090

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (machine-readable) or text (human-readable)
LOG_FORMAT=json

# OpenTelemetry Collector endpoint (if using external collector)
# Leave empty to disable OTEL export
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ============================================================================
# Evaluation Configuration
# ============================================================================

# Path to golden evaluation dataset (JSONL format)
EVAL_DATASET_PATH=./eval/golden_dataset.jsonl

# Comma-separated RAGAS metrics to compute
# Options: faithfulness, answer_relevancy, context_precision, context_recall
RAGAS_METRICS=faithfulness,answer_relevancy,context_precision,context_recall

# Batch size for evaluation (how many queries to evaluate in parallel)
EVAL_BATCH_SIZE=10

# ============================================================================
# Security Configuration
# ============================================================================

# API Key for authentication (leave empty to disable)
# If set, clients must include X-API-Key header
API_KEY=

# JWT Secret for token-based authentication
# Change this in production to a random secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT algorithm (HS256, RS256, etc.)
JWT_ALGORITHM=HS256

# JWT token expiration in minutes
JWT_EXPIRATION_MINUTES=60

# ============================================================================
# Feature Flags (Experimental Features)
# ============================================================================

# Enable query planning (break complex questions into sub-queries)
ENABLE_QUERY_PLANNING=true

# Enable self-reflection (agent evaluates its own responses)
ENABLE_SELF_REFLECTION=true

# Enable multi-query retrieval (retrieve with multiple query variations)
ENABLE_MULTI_QUERY=true

# ============================================================================
# Development Tools
# ============================================================================

# Enable debug toolbar in API responses
ENABLE_DEBUG_TOOLBAR=false

# Log SQL queries (very verbose!)
LOG_SQL_QUERIES=false

# Random seed for reproducibility (evaluation/testing)
RANDOM_SEED=42

# ============================================================================
# Notes
# ============================================================================
#
# 1. Development vs Production:
#    - For development: Use Ollama + Chroma (fast, local, free)
#    - For production: Use OpenAI/Gemini + Milvus (scalable, reliable)
#
# 2. Local vs Docker:
#    - Localhost: Use OLLAMA_BASE_URL=http://localhost:11434
#    - Docker: Use OLLAMA_BASE_URL=http://ollama:11434
#
# 3. Security:
#    - NEVER commit .env to version control
#    - Use different secrets for dev/staging/production
#    - Rotate API keys regularly
#
# 4. Performance:
#    - Adjust CHUNK_SIZE based on your documents
#    - Increase RETRIEVAL_TOP_K for higher recall
#    - Tune SIMILARITY_THRESHOLD based on your use case
#
